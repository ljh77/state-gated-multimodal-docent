{
  "dataset_name": "State-Gated Multimodal Interaction — Gating Evaluation Logs",
  "description": "Per-event sensor-state logs (person detection P, frontal-face F, voice-activity V) collected from a real-time digital-human docent system. Each record is a Voice-Activity-Detection event with its objectively logged P/F/V state, enabling offline recomputation of four gating policies. Ground-truth labels are derived solely from the logged sensor states, not from transcribed text.",
  "manuscript": "A State-Gated Multimodal Interaction Framework for Real-World Digital Human Systems (IEEE Access, #Access-2026-23083)",
  "collection_note": "Single-participant internal evaluation in an indoor office. Self-loop (system-playback) events excluded via the during_playback flag. Background-audio false activations induced with radio (speech content). Sample size and single-user scope are acknowledged limitations.",
  "gating_definitions": {
    "voice_only": "V (equivalent to always-on baseline)",
    "person_voice": "P AND V",
    "face_voice": "F AND V",
    "full": "P AND F AND V (proposed)"
  },
  "field_schema": {
    "sample_id": "sequential id (1..N)",
    "source_session": "originating log session",
    "condition": "acoustic condition (quiet / radio_background_audio)",
    "P_person": "1 if a person was detected (YOLOv8n), else 0",
    "F_frontal": "1 if frontal face (keypoint-symmetry hysteresis), else 0",
    "V_voice": "1 if voice activity (Silero VAD), else 0",
    "ground_truth": "true_positive (frontal user speech) or false_positive (unintended)",
    "subtype": "frontal_user_speech / non_frontal_person / no_person_background_audio",
    "gating_activation": "activation (1/0) of each gating policy for this event",
    "stt_ms": "faster-whisper STT time (ms)",
    "vad_ms": "VAD processing time (ms)"
  },
  "summary": {
